{
	"name": "@kimchi-dev/cli",
	"version": "0.0.0",
	"description": "kimchi — a coding agent CLI powered by Cast AI",
	"type": "module",
	"license": "MIT",
	"bin": {
		"kimchi": "src/entry.ts"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc --noEmit && node scripts/copy-resources.js --dev",
		"build:binary": "node scripts/build-binary.js",
		"install:local": "node scripts/install-local.js",
		"build:binary-linux-arm64": "node scripts/build-binary.js --target linux-arm64",
		"build:binary-linux-x64": "node scripts/build-binary.js --target linux-x64",
		"dev": "bun run --preload ./src/set-package-dir.ts src/entry.ts",
		"lint": "biome check src/ scripts/",
		"lint:fix": "biome check --write src/ scripts/",
		"typecheck": "tsc --noEmit",
		"check": "pnpm run lint && pnpm run typecheck",
		"test": "vitest run --dir src",
		"test:smoke": "vitest run --config tests/smoke/vitest.config.ts",
		"prepare": "husky",
		"verify": "pnpm run check && pnpm run build:binary && pnpm run test && pnpm run test:smoke"
	},
	"piConfig": {
		"name": "kimchi",
		"configDir": ".config/kimchi/harness"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.19.0",
		"@clack/prompts": "^1.2.0",
		"@earendil-works/pi-coding-agent": "^0.74.0",
		"@earendil-works/pi-tui": "^0.74.0",
		"@modelcontextprotocol/ext-apps": "^1.2.2",
		"@modelcontextprotocol/sdk": "^1.25.1",
		"@types/proper-lockfile": "^4.1.4",
		"micromatch": "^4.0.8",
		"open": "^10.2.0",
		"proper-lockfile": "^4.1.2",
		"shell-quote": "^1.8.3",
		"tar": "^7.5.13",
		"undici": "^8.0.2",
		"uuid": "^14.0.0",
		"yaml": "^2.8.4",
		"zod": "^4.0.0"
	},
	"peerDependencies": {
		"typebox": "*"
	},
	"optionalDependencies": {
		"@mariozechner/clipboard-darwin-arm64": "0.3.2",
		"@mariozechner/clipboard-darwin-universal": "0.3.2",
		"@mariozechner/clipboard-darwin-x64": "0.3.2",
		"@mariozechner/clipboard-linux-arm64-gnu": "0.3.2",
		"@mariozechner/clipboard-linux-arm64-musl": "0.3.2",
		"@mariozechner/clipboard-linux-x64-gnu": "0.3.2",
		"@mariozechner/clipboard-linux-x64-musl": "0.3.2",
		"@mariozechner/clipboard-win32-arm64-msvc": "0.3.2",
		"@mariozechner/clipboard-win32-x64-msvc": "0.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@earendil-works/pi-ai": "^0.74.0",
		"@mixmark-io/domino": "^2.2.0",
		"@types/micromatch": "^4.0.10",
		"@types/node": "^22.15.2",
		"@types/shell-quote": "^1.7.5",
		"@types/tar": "^7.0.87",
		"@types/turndown": "^5.0.5",
		"husky": "^9.1.7",
		"node-pty": "^1.1.0",
		"playwright": "^1.52.0",
		"tsx": "^4.21.0",
		"turndown": "^7.2.0",
		"typescript": "^5.7.3",
		"vitest": "^3.1.1"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@10.8.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild",
			"koffi",
			"node-pty",
			"protobufjs"
		],
		"patchedDependencies": {
			"@earendil-works/pi-coding-agent": "patches/@earendil-works__pi-coding-agent.patch"
		}
	}
}
